{{#section 'css'}}
<link rel="stylesheet" href="/css/app.css">
<link rel="stylesheet" href="/css/profile.css">
{{/section}}

<div class="container-profile">
    <div class="profile-avatar">
        <div class="container-header-cropper">
            {{#if user.background.url}}
                <img class="main-header-user" src="{{user.background.url}}" alt="">
            {{else}}
                {{!-- {{log user.username}} --}}
                <img class="preview-main-header-user" src="{{user.background.url}}" alt="">

                <div class="header-fallback"
                    style="background: {{backgroundColor user.username}};">
                </div>
            {{/if}}
        </div>
        <div class="info-user">
            <div class="avatar-user">
                {{#if user.avatar.url}}
                    <img class="main-avatar-user" src="{{user.avatar.url}}" alt="">
                {{else}}
                    {{!-- {{log user.username}} --}}
                    <img class="preview-main-avatar-user" src="{{user.avatar.url}}" alt="">

                    <div class="avatar-fallback"
                        style="background-color: {{avatarColor user.username}};">
                        <h1 class="first-char">
                            {{firstChar user.username}}
                        </h1>
                    </div>
                {{/if}}
                <div class="upload-avatar-btn">
                    <label for="avatar-image">Update image</label>
                    <input type="file" name="avatar" id="avatar-image" hidden>
                </div>
            </div>
            <div class="name-user">
                <h2>{{user.username}}</h2>
            </div>
            <div class="upload-header-btn">
                <label for="header-image">Upload header image</label>
                <input type="file" name="" id="header-image" hidden>
            </div>
        </div>
        <div class="content-profile">
            <div class="content-l">
                <div class="nav-content-l">
                    <ul>
                        <li>All</li>
                        <li>Tracks</li>
                    </ul>
                </div>
            </div>
            <div class="content-right">
                <div class="user-stats">
                    <ul>
                        <li>
                            Followers
                            <span>{{user.followersCount}}</span>
                        </li>
                        <li>
                            Following
                            <span>{{user.followingCount}}</span>
                        </li>
                        <li>
                            Tracks
                            <span>0</span>
                        </li>
                    </ul>
                </div>
                <div class="song-like-list">
                    <h2 class="title-content-r title-liked-js">{{ count }} Likes</h2>
                    <a class="view-all-text" href="/you/likes">View all</a>
                    <div class="list-liked">
                        {{#each likedMusics}}
                            {{#if (limited @index 3)}}
                                <div class="song-card js-song-card" data-id="{{this._id}}">
                                    <div class="container-thumbnail">
                                        <div class="control-btn">
                                            <img src="{{this.image}}" alt="" class="thumbnail-song">
                                            <button class="thumbnail-play-btn cursor-pointer js-play-btn">
                                                <svg class="icon-play" width="40" height="40" viewBox="0 0 24 24">
                                                    <path d="M8 5v14l11-7z"></path>
                                                </svg>
        
                                                <svg class="icon-pause"  width="40" height="40" viewBox="0 0 24 24">
                                                    <path d="M6 5h4v14H6zm8 0h4v14h-4z"></path>
                                                </svg>
                                            </button>
                                            
                                        </div>
                                    </div>
                                    <div class="song-info">
                                        <p class="artist-name shows-3-dots">{{this.artist}}</p>
                                        <a href="" class="song-name shows-3-dots">{{this.song_name}}</a>
                                        <audio class="js-audio"  src="{{this.file}}" preload="metadata"></audio>
                                    <div class="song-stats">
                                            <span class="play">
                                                <svg class="icon" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                                                    <path d="M8 5v14l11-7z"/>
                                                </svg>
                                                2,086
                                            </span>

                                            <span class="likes">
                                                <svg class="icon" width="13" height="13" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2">
                                                    <path d="M20.8 4.6c-1.5-1.5-4-1.5-5.5 0L12 7.9 8.7 4.6c-1.5-1.5-4-1.5-5.5 0s-1.5 4 0 5.5L12 21l8.8-10.9c1.5-1.5 1.5-4 0-5.5z"/>
                                                </svg>
                                                64
                                            </span>
                                        </div>
                                        
                                    </div>
                                    <div class="like-btn">
                                        <button class="thumbnail-like-btn cursor-point">
                                                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2">
                                                    <path d="M20.8 4.6c-1.5-1.5-4-1.5-5.5 0L12 7.9 8.7 4.6c-1.5-1.5-4-1.5-5.5 0s-1.5 4 0 5.5L12 21l8.8-10.9c1.5-1.5 1.5-4 0-5.5z"/>
                                                </svg>
                                        </button>
                                    </div>
                                </div>
                            {{/if}}
                        {{/each}}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="overlay overlay-avatar">
    <div class="form-avatar">
        <div class="preview-container">
            <div class="suggest-form-avatar">
                <h1>{{user.username}}</h1>
                <p>For best results, upload images of at least 1000x1000 pixels. 2MB file-size limit.</p>
            </div>
            <div class="image-container">
                <img src="" alt="" class="preview-image">
            </div>

            <div class="footer-form-avatar">
                <div class="zoom-image zoom-avatar-js">
                    <button class="zoom-out zoom-out-avatar-js">-</button>
                    <input type="range" class="zoom-slider" min="1" max="3" step="0.1" value="1">
                    <button class="zoom-in zoom-in-avatar-js">+</button>
                </div>

                <div class="btn-submit">
                    <button class="cancel-btn">Cancel</button>
                    <button type="submit" class="save-avatar-btn">Save</button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="overlay overlay-header">
    <div class="form-header-cropper">
        <div class="header-preview-container">
            <div class="suggest-header-cropper">
                <h1>Position and resize your profile header</h1>
                <p>For best results, upload PNG or JPG images of at least 2480x520 pixels. 2MB file-size limit. Avoid using text within your header image, as it will be cropped on smaller screens.</p>
            </div>
            <div class="header-image-container">
                <img src="" alt="" class="preview-header-image">
            </div>

            <div class="footer-header-cropper">
                <div class="zoom-image zoom-header-js">
                    <button class="zoom-out zoom-out-header-js">-</button>
                    <input type="range" class="zoom-slider" min="1" max="3" step="0.1" value="1">
                    <button class="zoom-in zoom-in-header-js">+</button>
                </div>

                <div class="btn-submit">
                    <button class="cancel-btn">Cancel</button>
                    <button type="submit" class="save-header-btn">Save</button>
                </div>
            </div>
        </div>
    </div>
</div>

<script type="module" src="/javascripts/views/profile.js"></script>